// schema.prisma
// Database schema for PostgreSQL multi-tenancy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String   @id @default(uuid())
  name            String
  subdomain       String   @unique
  resellerId      String?
  isActive        Boolean  @default(true)
  settings        Json     // Stores toggles like model_swapper, pii_anonymizer, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  leads           Lead[]
  botSessions     BotSession[]
  shadowAudits    ShadowAudit[]

  wipedAt         DateTime? // GDPR Kill-Switch implementation
  leadsBilled     Int       @default(0) // Stripe metered billing usage
  
  reseller        Reseller? @relation(fields: [resellerId], references: [id])
}

model Reseller {
  id              String   @id @default(uuid())
  companyName     String
  markupPercent   Float    @default(0.0)
  whitelabelLogo  String?
  customDomain    String?

  tenants         Tenant[]
}

model User {
  id              String   @id @default(uuid())
  tenantId        String
  email           String   @unique
  passwordHash    String?
  ssoProvider     String?  // Entra, Google, etc.
  role            String   @default("User") // Admin, User

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

model Lead {
  id              String   @id @default(uuid())
  tenantId        String
  whatsappId      String
  encryptedPII    String   // The Zero-Knowledge Lead Vault implementation
  urgencyScore    Int      @default(0) // Used by Dark Scarcity Engine
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  sessions        BotSession[]
}

model BotSession {
  id              String   @id @default(uuid())
  tenantId        String
  leadId          String
  transcript      Json     // Array of message logs
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  lead            Lead     @relation(fields: [leadId], references: [id])
}

model ShadowAudit {
  id              String   @id @default(uuid())
  tenantId        String
  riskHeatmap     Json
  identifiedGaps  Json
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}
